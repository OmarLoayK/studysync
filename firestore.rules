rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function allowedUserKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'updatedAt',
        'settings',
        'studyProfile',
        'onboarding'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && allowedUserKeys();
      allow delete: if false;

      match /tasks/{taskId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /aiGenerations/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /studyPlans/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /quizzes/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /flashcards/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /notes/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }
  }
}
